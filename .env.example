# ============================================================
# 排球訓練小幫手 — 環境變數設定範本
# 複製本檔案為 .env，再填入你的真實金鑰
# ============================================================

# Supabase（到 Supabase 後台 → Project Settings → API 取得）
SUPABASE_URL=https://你的專案ID.supabase.co
SUPABASE_ANON_KEY=你的_anon_key

# Google Gemini API（到 https://aistudio.google.com/apikey 取得）
GEMINI_API_KEY=你的_gemini_api_key

# 使用的 Gemini 模型（1.5 系列已退役，預設 gemini-3.5-flash，免費額度可用）
GEMINI_MODEL=gemini-3.5-flash

# App 通行碼（部署上線後避免陌生人使用；留空 = 不啟用密碼）
APP_PASSWORD=

# 教練後台密碼（新增/編輯學員、生成菜單的權限；上線前務必設定！）
ADMIN_PASSWORD=
